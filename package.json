{
  "name": "t2sr",
  "version": "0.1.0",
  "private": true,
  "description": "Site vitrine T2SR + API Hono pour demandes de devis",
  "workspaces": [
    "apps/website",
    "apps/api"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:website": "bun run --cwd apps/website dev",
    "dev:api": "bun run --cwd apps/api dev",
    "build": "bun run --cwd apps/website build",
    "build:website": "bun run --cwd apps/website build",
    "start:api": "bun run --cwd apps/api start",
    "preview": "bun run --cwd apps/website preview"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}

# --- Serveur API ---
PORT=8787

# Origine autorisee pour CORS (le site Astro)
# En local: http://localhost:4321
WEBSITE_ORIGIN=https://t2sr.fr

# --- Base de donnees ---
DATABASE_PATH=./data/t2sr.sqlite

# Dossier de stockage des fichiers uploades (HORS dossier public)
UPLOAD_DIR=./uploads

# --- Rate limiting ---
# Fenetre en millisecondes et nombre max de requetes par IP sur la fenetre
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5

# --- SMTP (envoi des notifications de devis) ---
# Laisser vide pour desactiver l'envoi d'email (les devis restent enregistres en base)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=devis@t2sr.fr
SMTP_TO=contact@t2sr.fr

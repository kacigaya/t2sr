---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuoteForm from "../components/QuoteForm.astro";
import { Section, SectionContainer } from "../components/ui/section";
import { Badge } from "../components/ui/badge";
import { SITE } from "../data/site";
import FadeInText from "@astroanimate/core/FadeInText";

const title = "Demande de devis peinture et rénovation | T2SR";
const description =
  "Demandez votre devis gratuit T2SR pour vos travaux de peinture, rénovation, installation cuisine ou travaux du bâtiment à Savigny-le-Temple et en Île-de-France.";
---

<BaseLayout title={title} description={description} path="/demande-de-devis">
  <Section class="bg-muted/50">
    <SectionContainer>
      <FadeInText class="max-w-2xl" duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Devis gratuit</Badge>
        <h1>Demander un devis</h1>
        <p>
          Décrivez votre projet de travaux à {SITE.city} ou en {SITE.region}.
          Plus votre description est précise, plus l'estimation sera juste.
        </p>
      </FadeInText>
    </SectionContainer>
  </Section>

  <Section>
    <SectionContainer class="max-w-3xl">
      <QuoteForm />
    </SectionContainer>
  </Section>
</BaseLayout>

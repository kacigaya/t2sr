---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import ServiceCard from "../components/ServiceCard.astro";
import WorkStep from "../components/WorkStep.astro";
import QuoteForm from "../components/QuoteForm.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import { Section, SectionContainer } from "../components/ui/section";
import { Badge } from "../components/ui/badge";
import { Button } from "../components/ui/button";
import { Card, CardHeader, CardTitle, CardContent } from "../components/ui/card";
import { SITE } from "../data/site";
import { SERVICES } from "../data/services";
import FadeInText from "@astroanimate/core/FadeInText";
import ScaleIn from "@astroanimate/core/ScaleIn";

const trust = [
  { title: "Devis clair", text: "Une estimation détaillée et transparente avant de démarrer." },
  { title: "Intérieur & extérieur", text: "Travaux de peinture et rénovation, dedans comme dehors." },
  { title: "Accompagnement personnalisé", text: "Un interlocuteur à l'écoute de votre projet." },
  { title: "Photos pour estimer", text: "Envoyez vos photos pour une première estimation à distance." },
];

const steps = [
  "Choisir le type de travaux",
  "Décrire le projet",
  "Indiquer les pièces concernées",
  "Préciser la surface",
  "Ajouter des photos",
  "Recevoir un retour",
];

const homeServices = SERVICES.slice(0, 6);

const title = "Peinture et rénovation à Savigny-le-Temple | T2SR";
const description =
  "T2SR : peinture intérieure et extérieure, rénovation, installation cuisine et travaux du bâtiment à Savigny-le-Temple, en Seine-et-Marne et en Île-de-France. Demandez votre devis.";
---

<BaseLayout title={title} description={description} path="/">
  <HeroSection />

  <!-- Confiance -->
  <Section>
    <SectionContainer>
      <FadeInText class="mx-auto max-w-3xl text-center" enhance duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Pourquoi T2SR</Badge>
        <h2>Qui réalise vos travaux</h2>
      </FadeInText>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          trust.map((item, i) => (
            <ScaleIn enhance initialScale={0.96} duration={380} delay={i * 45} margin="0px 0px -8% 0px">
            <Card class="h-full">
              <CardHeader>
                <CardTitle class="!text-lg !font-bold">{item.title}</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground">{item.text}</p>
              </CardContent>
            </Card>
            </ScaleIn>
          ))
        }
      </div>
    </SectionContainer>
  </Section>

  <!-- Comment obtenir un devis -->
  <Section class="bg-muted/50">
    <SectionContainer>
      <FadeInText class="max-w-2xl" enhance duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Simple et rapide</Badge>
        <h2>Comment obtenir un devis ?</h2>
        <p>Six étapes pour décrire votre projet et recevoir une estimation.</p>
      </FadeInText>
      <ol class="grid list-none gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3">
        {steps.map((step, i) => <WorkStep step={i + 1} title={step} />)}
      </ol>
      <ScaleIn class="text-center" enhance initialScale={0.97} duration={380} margin="0px 0px -8% 0px">
        <Button as="a" href="/demande-de-devis" size="lg">Démarrer ma demande</Button>
      </ScaleIn>
    </SectionContainer>
  </Section>

  <!-- Services -->
  <Section>
    <SectionContainer>
      <FadeInText class="max-w-2xl" enhance duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Nos prestations</Badge>
        <h2>Des services pour tous vos travaux</h2>
        <p>Peinture, rénovation, vitrerie, installation de cuisine et petits travaux du bâtiment.</p>
      </FadeInText>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {homeServices.map((service) => <ServiceCard service={service} />)}
      </div>
      <ScaleIn class="text-center" enhance initialScale={0.97} duration={380} margin="0px 0px -8% 0px">
        <Button as="a" href="/services" variant="outline" size="lg">Voir tous les services</Button>
      </ScaleIn>
    </SectionContainer>
  </Section>

  <!-- Avant / Après -->
  <Section class="bg-muted/50">
    <SectionContainer>
      <FadeInText class="mx-auto max-w-3xl text-center" enhance duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Avant / Après</Badge>
        <h2>Le rendu de nos travaux</h2>
        <p>
          Les visuels ci-dessous sont des emplacements réservés. Les photos de
          chantiers réels seront ajoutées prochainement.
        </p>
      </FadeInText>
      <div class="grid gap-6 sm:grid-cols-2">
        <BeforeAfter category="Peinture" label="Séjour" />
        <BeforeAfter category="Rénovation" label="Pièce à vivre" />
      </div>
    </SectionContainer>
  </Section>

  <!-- Formulaire de devis -->
  <Section id="devis">
    <SectionContainer class="max-w-3xl">
      <FadeInText enhance duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Demande de devis</Badge>
        <h2>Décrivez votre projet</h2>
        <p>
          Remplissez le formulaire : nous revenons vers vous avec une première
          estimation. Champs marqués <span class="text-primary">*</span> obligatoires.
        </p>
      </FadeInText>
      <QuoteForm />
    </SectionContainer>
  </Section>

  <!-- Contact rapide -->
  <Section class="bg-anthracite text-white">
    <SectionContainer class="flex-row flex-wrap items-center justify-between gap-6">
      <FadeInText duration={0.5} blur="4px" yOffset={12}>
        <h2 class="text-white">Un projet à {SITE.city} ou en {SITE.region} ?</h2>
        <p class="!text-white/70">Contactez T2SR pour discuter de vos travaux.</p>
      </FadeInText>
      <ScaleIn class="flex flex-wrap gap-4" enhance initialScale={0.97} duration={380} margin="0px 0px -8% 0px">
        <Button as="a" href="/contact" size="lg">Nous contacter</Button>
        <Button as="a" href="/demande-de-devis" variant="outline" size="lg"
          class="!border-white/40 !bg-transparent !text-white hover:!bg-white/10">Demander un devis</Button>
      </ScaleIn>
    </SectionContainer>
  </Section>
</BaseLayout>

<style>
  .bg-anthracite {
    background: var(--color-anthracite);
  }
</style>

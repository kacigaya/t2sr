---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Section, SectionContainer } from "../components/ui/section";
import { Badge } from "../components/ui/badge";
import { Button } from "../components/ui/button";
import { Card, CardHeader, CardTitle, CardContent } from "../components/ui/card";
import { Item, ItemContent, ItemTitle, ItemDescription } from "../components/ui/item";
import { Separator } from "../components/ui/separator";
import { SITE, SERVICE_AREAS } from "../data/site";
import FadeInText from "@astroanimate/core/FadeInText";
import ScaleIn from "@astroanimate/core/ScaleIn";

const title = "Contact | T2SR peinture et rénovation";
const description =
  "Contactez T2SR pour vos travaux de peinture et rénovation à Savigny-le-Temple, en Seine-et-Marne et en Île-de-France. Téléphone, email et demande de devis.";

const phoneHref = SITE.phone ? `tel:${SITE.phone.replace(/\s+/g, "")}` : null;
const emailHref = SITE.email ? `mailto:${SITE.email}` : null;

const rows = [
  ["Téléphone", SITE.phone, phoneHref],
  ["Email", SITE.email, emailHref],
  ["Adresse", SITE.address, null],
] as const;
---

<BaseLayout title={title} description={description} path="/contact">
  <Section class="bg-muted/50">
    <SectionContainer>
      <FadeInText class="max-w-2xl" duration={0.5} blur="4px" yOffset={12}>
        <Badge variant="outline" class="mb-2 uppercase tracking-wider">Contact</Badge>
        <h1>Parlons de votre projet</h1>
        <p>T2SR intervient à {SITE.city}, en {SITE.department} et plus largement en {SITE.region}.</p>
      </FadeInText>
    </SectionContainer>
  </Section>

  <Section>
    <SectionContainer>
      <div class="grid gap-6 md:grid-cols-2">
        <ScaleIn enhance initialScale={0.96} duration={420} margin="0px 0px -8% 0px">
        <Card class="h-full">
          <CardHeader>
            <CardTitle class="!text-xl !font-bold">Coordonnées</CardTitle>
          </CardHeader>
          <CardContent class="flex flex-col gap-1">
            {
              rows.map(([label, value, href], i) => (
                <>
                  {i > 0 && <Separator />}
                  <Item variant="default" class="px-0">
                    <ItemContent>
                      <ItemDescription class="!text-xs uppercase tracking-wider">{label}</ItemDescription>
                      <ItemTitle class="!text-base">
                        {href ? <a href={href}>{value}</a> : (value || "À compléter")}
                      </ItemTitle>
                    </ItemContent>
                  </Item>
                </>
              ))
            }
            <div class="mt-4 flex flex-wrap gap-3">
              {phoneHref && <Button as="a" href={phoneHref}>Appeler</Button>}
              {emailHref && <Button as="a" href={emailHref} variant="outline">Envoyer un email</Button>}
              <Button as="a" href="/demande-de-devis" variant="outline">Demander un devis</Button>
            </div>
          </CardContent>
        </Card>
        </ScaleIn>

        <ScaleIn enhance initialScale={0.96} duration={420} delay={45} margin="0px 0px -8% 0px">
        <Card class="h-full">
          <CardHeader>
            <CardTitle class="!text-xl !font-bold">Zone d'intervention</CardTitle>
          </CardHeader>
          <CardContent>
            <p>T2SR se déplace dans les secteurs suivants :</p>
            <ul class="my-2 list-none p-0">
              {SERVICE_AREAS.map((area) => (
                <li class="text-foreground border-border border-b py-2 font-semibold">{area}</li>
              ))}
            </ul>
            <p class="text-muted-foreground">
              Pour un secteur non listé, contactez-nous : nous étudions chaque demande.
            </p>
          </CardContent>
        </Card>
        </ScaleIn>
      </div>
    </SectionContainer>
  </Section>
</BaseLayout>

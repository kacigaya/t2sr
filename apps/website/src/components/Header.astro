---
import { SITE } from "../data/site";
import { Button } from "./ui/button";

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/services", label: "Services" },
  { href: "/realisations", label: "Réalisations" },
  { href: "/contact", label: "Contact" },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.name}, accueil`}>
      <img src="/logo.svg" alt="" width="40" height="40" />
      <span class="brand__name">{SITE.name}</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Ouvrir le menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Navigation principale">
      <ul>
        {
          navLinks.map((link) => {
            const linkPath = link.href.replace(/\/$/, "") || "/";
            const isActive = linkPath === current;
            return (
              <li>
                <a href={link.href} aria-current={isActive ? "page" : undefined}>
                  {link.label}
                </a>
              </li>
            );
          })
        }
        <li class="site-nav__cta">
          <Button as="a" href="/demande-de-devis">Demander un devis</Button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 68px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 800;
    color: var(--color-anthracite);
    text-decoration: none;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
  }
  .brand:hover {
    text-decoration: none;
  }
  .site-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .site-nav a {
    color: var(--color-text);
    font-weight: 600;
    text-decoration: none;
  }
  .site-nav a[aria-current="page"] {
    color: var(--color-accent-dark);
  }
  .site-nav a:hover {
    color: var(--color-accent-dark);
  }
  .site-nav__cta a {
    color: #fff;
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-burger span {
    width: 24px;
    height: 2px;
    background: var(--color-anthracite);
    transition: var(--transition);
  }

  @media (max-width: 820px) {
    .nav-burger {
      display: flex;
    }
    .site-nav {
      position: absolute;
      top: 68px;
      left: 0;
      right: 0;
      background: var(--color-white);
      border-bottom: 1px solid var(--color-border);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .site-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem 1.25rem 1.25rem;
    }
    .site-nav li {
      padding: 0.4rem 0;
    }
    .site-nav__cta {
      margin-top: 0.5rem;
    }
    .nav-toggle:checked ~ .site-nav {
      max-height: 380px;
    }
  }
</style>

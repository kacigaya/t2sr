---
import { SITE } from "../data/site";
import { SERVICES } from "../data/services";
import { Form } from "./ui/form";
import { Field, FieldLabel, FieldSet, FieldLegend, FieldGroup, FieldDescription } from "./ui/field";
import { Input } from "./ui/input";
import { Textarea } from "./ui/textarea";
import { NativeSelect, NativeSelectOption } from "./ui/native-select";
import { Checkbox } from "./ui/checkbox";
import { Button } from "./ui/button";
import ScaleIn from "@astroanimate/core/ScaleIn";

const apiUrl = SITE.apiUrl;

const rooms = [
  ["cuisine", "Cuisine"],
  ["salon", "Salon"],
  ["chambre", "Chambre"],
  ["salle-de-bain", "Salle de bain"],
  ["wc", "WC"],
  ["couloir", "Couloir"],
  ["escalier", "Escalier"],
  ["garage", "Garage"],
  ["cave", "Cave"],
  ["facade", "Façade"],
  ["terrasse", "Terrasse"],
  ["bureau", "Bureau"],
  ["commerce", "Commerce"],
  ["autre", "Autre"],
];

const surfaces = [
  ["moins-10", "Moins de 10 m²"],
  ["10-30", "10 à 30 m²"],
  ["30-60", "30 à 60 m²"],
  ["60-100", "60 à 100 m²"],
  ["plus-100", "Plus de 100 m²"],
  ["inconnu", "Je ne sais pas"],
];

const supports = [
  ["neuf", "Neuf"],
  ["bon", "Bon état"],
  ["rafraichir", "À rafraîchir"],
  ["abime", "Abîmé"],
  ["renover", "À rénover complètement"],
];

const budgets = [
  ["moins-1000", "Moins de 1 000 €"],
  ["1000-3000", "1 000 € à 3 000 €"],
  ["3000-10000", "3 000 € à 10 000 €"],
  ["plus-10000", "Plus de 10 000 €"],
  ["a-definir", "À définir"],
];

const deadlines = [
  ["urgent", "Urgent"],
  ["1-mois", "Sous 1 mois"],
  ["3-mois", "Sous 3 mois"],
  ["flexible", "Flexible"],
];
---

<ScaleIn enhance initialScale={0.98} duration={420} margin="0px 0px -8% 0px">
<Form id="quote-form" class="quote-form ring-foreground/10 bg-card rounded-xl p-6 shadow-md ring-1 md:p-8" novalidate>
  <!-- Honeypot anti-spam: champ invisible qui doit rester vide. -->
  <div class="hp" aria-hidden="true">
    <label for="website">Ne pas remplir</label>
    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <FieldSet>
    <FieldLegend>Vos coordonnées</FieldLegend>
    <FieldGroup>
      <div class="grid gap-6 sm:grid-cols-2">
        <Field>
          <FieldLabel for="fullName">Nom complet <span class="req">*</span></FieldLabel>
          <Input type="text" id="fullName" name="fullName" required maxlength="200" autocomplete="name" />
        </Field>
        <Field>
          <FieldLabel for="phone">Téléphone <span class="req">*</span></FieldLabel>
          <Input type="tel" id="phone" name="phone" required autocomplete="tel" />
        </Field>
        <Field>
          <FieldLabel for="email">Email <span class="req">*</span></FieldLabel>
          <Input type="email" id="email" name="email" required autocomplete="email" />
        </Field>
        <Field>
          <FieldLabel for="city">Ville <span class="req">*</span></FieldLabel>
          <Input type="text" id="city" name="city" required maxlength="200" autocomplete="address-level2" />
        </Field>
      </div>
      <Field>
        <FieldLabel for="address">Adresse du chantier</FieldLabel>
        <Input type="text" id="address" name="address" maxlength="200" autocomplete="street-address" />
      </Field>
    </FieldGroup>
  </FieldSet>

  <FieldSet>
    <FieldLegend>Votre projet</FieldLegend>
    <FieldGroup>
      <Field>
        <FieldLabel for="workType">Type de travaux <span class="req">*</span></FieldLabel>
        <NativeSelect class="w-full" id="workType" name="workType" required>
          <NativeSelectOption value="">Sélectionnez un type</NativeSelectOption>
          {SERVICES.map((s) => <NativeSelectOption value={s.slug}>{s.title}</NativeSelectOption>)}
        </NativeSelect>
      </Field>

      <FieldSet>
        <FieldLegend variant="label">Pièces concernées</FieldLegend>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {
            rooms.map(([value, label]) => (
              <FieldLabel orientation="horizontal" class="bg-muted/40 rounded-lg border px-3 py-2">
                <Checkbox name="rooms" value={value} />
                <span>{label}</span>
              </FieldLabel>
            ))
          }
        </div>
      </FieldSet>

      <div class="grid gap-6 sm:grid-cols-2">
        <Field>
          <FieldLabel for="surface">Surface approximative</FieldLabel>
          <NativeSelect class="w-full" id="surface" name="surface">
            <NativeSelectOption value="">Non précisé</NativeSelectOption>
            {surfaces.map(([v, l]) => <NativeSelectOption value={v}>{l}</NativeSelectOption>)}
          </NativeSelect>
        </Field>
        <Field>
          <FieldLabel for="supportState">État du support</FieldLabel>
          <NativeSelect class="w-full" id="supportState" name="supportState">
            <NativeSelectOption value="">Non précisé</NativeSelectOption>
            {supports.map(([v, l]) => <NativeSelectOption value={v}>{l}</NativeSelectOption>)}
          </NativeSelect>
        </Field>
        <Field>
          <FieldLabel for="budget">Budget estimé</FieldLabel>
          <NativeSelect class="w-full" id="budget" name="budget">
            <NativeSelectOption value="">Non précisé</NativeSelectOption>
            {budgets.map(([v, l]) => <NativeSelectOption value={v}>{l}</NativeSelectOption>)}
          </NativeSelect>
        </Field>
        <Field>
          <FieldLabel for="deadline">Délai souhaité</FieldLabel>
          <NativeSelect class="w-full" id="deadline" name="deadline">
            <NativeSelectOption value="">Non précisé</NativeSelectOption>
            {deadlines.map(([v, l]) => <NativeSelectOption value={v}>{l}</NativeSelectOption>)}
          </NativeSelect>
        </Field>
      </div>

      <Field>
        <FieldLabel for="description">Description du projet <span class="req">*</span></FieldLabel>
        <Textarea id="description" name="description" rows="5" required maxlength="2000"
          placeholder="Décrivez votre projet : pièces, état actuel, attentes…" />
      </Field>

      <Field>
        <FieldLabel for="files">Photos (optionnel)</FieldLabel>
        <Input type="file" id="files" name="files" multiple accept="image/jpeg,image/png,image/webp" />
        <FieldDescription>JPG, PNG ou WebP. 5 fichiers maximum, 5 Mo par fichier.</FieldDescription>
      </Field>
    </FieldGroup>
  </FieldSet>

  <FieldLabel orientation="horizontal" class="bg-muted/40 items-start rounded-lg border px-4 py-3">
    <Checkbox id="consent" name="consent" value="true" required class="mt-0.5" />
    <span>
      J'accepte que mes données soient utilisées pour traiter ma demande de devis. <span class="req">*</span>
      <a href="/mentions-legales">En savoir plus</a>.
    </span>
  </FieldLabel>

  <div id="quote-message" class="quote-message" role="status" aria-live="polite" hidden></div>

  <Button type="submit" id="quote-submit" size="lg" class="w-full">
    Envoyer ma demande
  </Button>
</Form>
</ScaleIn>

<script define:vars={{ apiUrl }}>
  const form = document.getElementById("quote-form");
  const submitBtn = document.getElementById("quote-submit");
  const messageBox = document.getElementById("quote-message");

  // Prefill du type de travaux depuis ?service=slug
  const params = new URLSearchParams(window.location.search);
  const preselect = params.get("service");
  if (preselect) {
    const select = document.getElementById("workType");
    if (select && [...select.options].some((o) => o.value === preselect)) {
      select.value = preselect;
    }
  }

  const MAX_FILES = 5;
  const MAX_FILE_SIZE = 5 * 1024 * 1024;
  const ALLOWED = ["image/jpeg", "image/png", "image/webp"];

  function ShowMessage(type, text) {
    messageBox.hidden = false;
    messageBox.className = "quote-message quote-message--" + type;
    messageBox.textContent = text;
    messageBox.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  function ValidateClient() {
    const email = form.email.value.trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      return "Veuillez saisir un email valide.";
    }
    const phone = form.phone.value.trim();
    if (!/^[+]?[\d\s().-]{6,20}$/.test(phone)) {
      return "Veuillez saisir un numéro de téléphone valide.";
    }
    if (!form.consent.checked) {
      return "Le consentement est obligatoire.";
    }
    const files = form.files.files;
    if (files.length > MAX_FILES) {
      return "Maximum " + MAX_FILES + " fichiers.";
    }
    for (const f of files) {
      if (f.size > MAX_FILE_SIZE) return 'Le fichier "' + f.name + '" dépasse 5 Mo.';
      if (!ALLOWED.includes(f.type)) return 'Type non autorisé : "' + f.name + '".';
    }
    return null;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    messageBox.hidden = true;

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const clientError = ValidateClient();
    if (clientError) {
      ShowMessage("error", clientError);
      return;
    }

    submitBtn.disabled = true;
    const originalLabel = submitBtn.textContent;
    submitBtn.textContent = "Envoi en cours…";

    try {
      const formData = new FormData(form);
      const res = await fetch(apiUrl + "/api/quotes", {
        method: "POST",
        body: formData,
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok && data.success) {
        form.reset();
        ShowMessage(
          "success",
          "Merci ! Votre demande a bien été envoyée. Nous vous recontactons rapidement.",
        );
      } else {
        ShowMessage("error", data.error || "Une erreur est survenue. Réessayez.");
      }
    } catch {
      ShowMessage(
        "error",
        "Impossible d'envoyer la demande. Vérifiez votre connexion et réessayez.",
      );
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;
    }
  });
</script>

<style>
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .req {
    color: var(--color-accent-dark);
  }
  .quote-message {
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
  }
  .quote-message--success {
    background: #e6f5ec;
    color: var(--color-success);
    border: 1px solid var(--color-success);
  }
  .quote-message--error {
    background: #fbeae8;
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }
</style>

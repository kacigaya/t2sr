---
import { SITE, SERVICE_AREAS } from "../data/site";
import { Separator } from "./ui/separator";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <div class="brand">
        <img src="/logo.svg" alt="" width="36" height="36" loading="lazy" decoding="async" />
        <span>{SITE.name}</span>
      </div>
      <p>{SITE.tagline}.</p>
      <p class="muted">
        SIREN {SITE.siren}, {SITE.apeLabel} (APE {SITE.ape})
      </p>
    </div>

    <div>
      <h3>Navigation</h3>
      <ul>
        <li><a href="/">Accueil</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/realisations">Réalisations</a></li>
        <li><a href="/demande-de-devis">Demander un devis</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/mentions-legales">Mentions légales</a></li>
      </ul>
    </div>

    <div>
      <h3>Zone d'intervention</h3>
      <ul>
        {SERVICE_AREAS.map((area) => <li>{area}</li>)}
      </ul>
    </div>
  </div>

  <div class="container"><Separator class="!bg-white/15" /></div>

  <div class="container site-footer__bottom">
    <p>© {year} {SITE.name}. Tous droits réservés.</p>
    <a href="/mentions-legales">Mentions légales</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-anthracite);
    color: #c7cbd3;
    padding-top: 3rem;
  }
  .site-footer__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .site-footer__grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #fff;
    font-weight: 800;
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }
  .site-footer h3 {
    color: #fff;
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }
  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .site-footer li {
    padding: 0.25rem 0;
  }
  .site-footer a {
    color: #c7cbd3;
  }
  .site-footer a:hover {
    color: var(--color-accent);
  }
  .site-footer p {
    color: #c7cbd3;
  }
  .muted {
    font-size: 0.85rem;
    color: #9aa0ab;
  }
  .site-footer__bottom {
    margin-top: 1.25rem;
    padding-block: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: space-between;
    font-size: 0.85rem;
  }
</style>

---
import { SITE } from "../data/site";
import { Badge } from "./ui/badge";
import { Button } from "./ui/button";
import FadeInText from "@astroanimate/core/FadeInText";
import ScaleIn from "@astroanimate/core/ScaleIn";
---

<section class="hero">
  <div class="container hero__inner">
    <FadeInText class="hero__content" duration={0.55} blur="4px" yOffset={14}>
      <Badge class="mb-3 uppercase tracking-wider">{SITE.city} · {SITE.region}</Badge>
      <h1>T2SR : peinture, rénovation et travaux du bâtiment</h1>
      <p class="hero__lead">
        Travaux intérieurs et extérieurs à {SITE.city} et en {SITE.region}.
      </p>
      <ScaleIn enhance initialScale={0.97} duration={450} delay={150}>
        <div class="hero__actions">
          <Button as="a" href="/demande-de-devis" size="lg">Demander un devis</Button>
          <Button
            as="a"
            href="/services"
            variant="outline"
            size="lg"
            class="!border-white/40 !bg-transparent !text-white hover:!bg-white/10"
          >
            Voir les services
          </Button>
        </div>
      </ScaleIn>
      <ul class="hero__points">
        <li>Devis clair</li>
        <li>Intérieur &amp; extérieur</li>
        <li>Accompagnement personnalisé</li>
      </ul>
    </FadeInText>
  </div>
</section>

<style>
  .hero {
    background:
      linear-gradient(rgba(35, 38, 43, 0.82), rgba(35, 38, 43, 0.92)),
      repeating-linear-gradient(
        45deg,
        #2a2e34,
        #2a2e34 22px,
        #262a30 22px,
        #262a30 44px
      );
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 6px;
    background: var(--color-accent);
  }
  .hero__inner {
    padding-block: clamp(4rem, 10vw, 7rem);
  }
  .hero__content {
    max-width: 680px;
  }
  .hero h1 {
    color: #fff;
  }
  .hero__lead {
    font-size: 1.2rem;
    color: #d7dae0;
    max-width: 540px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 1.75rem 0 2rem;
  }
  .hero__points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .hero__points li {
    position: relative;
    padding-left: 1.5rem;
    color: #e6e8ec;
    font-weight: 600;
  }
  .hero__points li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 800;
  }
</style>

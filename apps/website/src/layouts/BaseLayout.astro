---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE, SERVICE_AREAS } from "../data/site";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path } = Astro.props;

// Schema.org — HomeAndConstructionBusiness (peinture / travaux du bâtiment).
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: SITE.name,
  description: `${SITE.tagline} à ${SITE.city} et en ${SITE.region}.`,
  url: SITE.url,
  ...(SITE.phone ? { telephone: SITE.phone } : {}),
  ...(SITE.email ? { email: SITE.email } : {}),
  address: {
    "@type": "PostalAddress",
    addressLocality: SITE.city,
    addressRegion: SITE.department,
    addressCountry: "FR",
  },
  areaServed: SERVICE_AREAS.map((a) => ({ "@type": "Place", name: a })),
  identifier: { "@type": "PropertyValue", name: "SIREN", value: SITE.siren },
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="theme-color" content="#23262b" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap"
    />
    <Seo title={title} description={description} path={path} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
